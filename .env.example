# FastAPI MySQL (job 진행상태)
MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_USER=chok_ai
MYSQL_PASSWORD=password
MYSQL_DB=chok_ai
# docker-compose에서만 사용 (앱은 안 읽음)
MYSQL_ROOT_PASSWORD=root

# Spring 게이트웨이
SPRING_BASE_URL=http://localhost:8080

# LLM (OpenAI) — 키가 비어 있으면 LLM 미기동
OPENAI_API_KEY=
OPENAI_MODEL_REPORT=gpt-5.5-2026-04-23
OPENAI_MODEL_ANALYSIS=gpt-5.4-mini-2026-03-17
OPENAI_MODEL_LIGHT=gpt-5.4-nano-2026-03-17
OPENAI_MAX_CONCURRENCY=4
OPENAI_MAX_RETRIES=3
OPENAI_MAX_INPUT_CHARS=120000
